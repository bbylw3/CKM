---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  breadcrumb: string;
  /** 顶部渐变起始色，默认为品牌色 tint */
  gradientFrom?: string;
  /** eyebrow 文字颜色，默认为品牌色 */
  eyebrowColor?: string;
}

const {
  eyebrow,
  title,
  description,
  breadcrumb,
  gradientFrom = 'var(--color-brand-tint)',
  eyebrowColor,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<section class="border-b border-line" style={`background:linear-gradient(180deg, ${gradientFrom} 0%, var(--color-bg) 100%)`}>
  <div class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <nav class="text-sm text-subtle mb-4" aria-label="面包屑">
      <a href={base} class="hover:text-brand">首页</a>
      <span class="mx-1.5">/</span>
      <span class="text-ink">{breadcrumb}</span>
    </nav>
    <p class="eyebrow mb-3" style={eyebrowColor ? `color:${eyebrowColor}` : undefined}>{eyebrow}</p>
    <h1 class="font-serif text-4xl lg:text-5xl font-bold text-ink mb-5 leading-tight">{title}</h1>
    <p class="text-lg text-muted leading-relaxed max-w-2xl">{description}</p>
  </div>
</section>
