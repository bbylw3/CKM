---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Cta from '../components/Cta.astro';
import Recommendation from '../components/Recommendation.astro';

const title = '特殊情况与监测 · CKM 健康指南';
const description = 'CKM 综合征的特殊情况：MASLD、OSA、妊娠、VTE，治疗监测与未来研究方向。';
const base = import.meta.env.BASE_URL;

const navCards = [
  { href: '#masld', chip: '肝脏', desc: 'MASLD 代谢功能障碍相关脂肪性肝病' },
  { href: '#osa', chip: '睡眠', desc: 'OSA 阻塞性睡眠呼吸暂停' },
  { href: '#pregnancy', chip: '妊娠', desc: '妊娠与 CKM 健康' },
  { href: '#vte', chip: '血栓', desc: '静脉血栓栓塞 (VTE)' },
  { href: '#monitoring', chip: '监测', desc: '治疗开始后的监测与随访' },
  { href: '#future', chip: '未来', desc: '证据空白与未来方向' },
];

const masldRecs = [
  { cor: '1' as const, loe: 'B-NR', body: '在伴 CKM 综合征且合并糖尿病或有 ≥ 2 项心脏代谢危险因素的成人中，推荐<strong>每 1 至 2 年</strong>计算一次 FIB-4 指数，以评估与 MASLD 相关的肝纤维化风险。' },
  { cor: '2a' as const, loe: 'C-LD', body: '在因存在糖尿病前期而被归为 CKM 1 期的成人中，<strong>每 2 至 3 年</strong>计算一次 FIB-4 指数以评估 MASLD 相关肝纤维化风险是合理的。' },
  { cor: '1' as const, loe: 'B-R', body: '对于伴 CKM 综合征和 MASLD 的成人，推荐通过体育活动和饮食方法进行生活方式干预以减轻体重，并根据需要辅助使用减重药物和/或 MBS，以减轻 MASLD 严重程度并改善 CKM 风险谱。' },
  { cor: '1' as const, loe: 'B-R', body: '对于伴 CKM 综合征和 MASLD 且合并 T2D，或伴 MASH 且有临床显著肝纤维化证据的成人，推荐使用已证实获益的 <strong>GLP-1 类疗法</strong>以促进 MASLD 的组织学改善。' },
];

const fib4Rows = [
  { age: '&lt; 35', fib4: '不适用', followup: '—', muted: true },
  { age: '35–64', fib4: '&lt; 1.3', followup: '常规监测', muted: false },
  { age: '35–64', fib4: '1.3–2.67', followup: '转诊 VCTE 或 ELF', muted: false },
  { age: '≥ 65', fib4: '1.3–2.0', followup: '常规监测', muted: false },
  { age: '≥ 65', fib4: '&gt; 2.0', followup: '转诊 VCTE 或 ELF', muted: false },
];

const masldCards = [
  { color: '#0d9488', title: '5%–10%', desc: '体重减轻 → 改善肝脏脂肪变性和炎症' },
  { color: '#0f766e', title: '≥ 10%', desc: '总体重减轻 → MASLD 缓解、纤维化改善、心脏代谢风险因素改善' },
  { color: '#be123c', title: 'GLP-1 类', desc: 'tirzepatide 在 T2D 中显示比胰岛素 degludec 更显著降低肝脏脂肪含量' },
];

const osaRecs = [
  { cor: '2a' as const, loe: 'C-LD', body: '对于伴 CKM 综合征和肥胖的成人，<strong>每年评估</strong>睡眠呼吸暂停症状（包括使用经验证的筛查工具）是合理的，以促进 OSA 的检出。' },
  { cor: '1' as const, loe: 'B-R', body: '对于伴 CKM 综合征和 OSA 的成人，治疗策略应当包括在有指征时进行<strong>体重管理干预</strong>，以及<strong>持续正压通气 (CPAP)</strong>和其他疗法，以改善 OSA 相关症状并降低 CKM 分期进展的风险。' },
];

const pregnancyPreRecs = [
  { cor: '1' as const, loe: 'B-NR', body: '对于计划妊娠且伴 CKM 综合征的个体，推荐在孕前通过生活方式干预和适当药物<strong>优化体重、肾功能、血糖和血压控制</strong>，以降低 APO 风险并优化产后 CKM 健康。' },
  { cor: '1' as const, loe: 'B-R', body: '对于计划妊娠且伴糖尿病的个体，推荐在孕前通过生活方式干预和必要时药物治疗优化血糖控制（目标 <strong>HbA1c &lt; 6.5%</strong>），以降低 APO 风险。' },
  { cor: '1' as const, loe: 'C-LD', body: '对于计划妊娠且伴 CKM 综合征 2 至 4 期的个体，应当由<strong>多学科照护团队</strong>提供照护，以降低 APO 风险并优化产后 CKM 健康。' },
];

const pregnancyPostRecs = [
  { cor: '1' as const, loe: 'B-NR', body: '对于经历过 APO 的个体，推荐在<strong>产后第一年内</strong>至少进行一次 CKM 危险因素筛查（包括血压、血脂、血糖、CKD 评估、BMI 和腰围）以及生活方式咨询。' },
  { cor: '1' as const, loe: 'B-NR', body: '对于经历过 APO 的个体，推荐从产后照护<strong>过渡到长期初级保健</strong>，以促进 CKM 危险因素的监测和 CKM 健康的优化。' },
];

const vteCards = [
  { chip: '首选药物', desc: '<strong>利伐沙班或阿哌沙班</strong>在大多数 CKM 患者中首选。' },
  { chip: '严重肥胖', desc: '在 BMI ≥ 50 kg/m² 或体重 &gt; 150 kg 患者中数据有限，需要个体化考虑。' },
  { chip: 'CKD 注意', chipBg: '#fffbeb', chipColor: '#b45309', chipBorder: '#fde68a', borderLeft: '#b45309', desc: '在 CKD 中，<strong>VTE 形成和抗凝相关出血风险均高</strong>。DOAC 剂量应根据肾功能调整。' },
  { chip: '华法林', desc: 'DOAC 优于华法林，但在特定情况下（如机械瓣膜、严重二尖瓣狭窄）华法林仍为必需。' },
];

const monitoringRecs = [
  { cor: '1' as const, loe: 'B-NR', body: '对于开始使用 GLP-1 类疗法进行减重的患者，应定期（<strong>3 至 6 个月内</strong>）重新评估减重的低反应性；如果减重不足（&lt; 5%），应通过剂量滴定、更换为具有相似获益的其他药物，和/或转诊至体重管理专家来优化减重。' },
  { cor: '1' as const, loe: 'A', body: '对于开始使用具有心脏保护作用的降糖药物（SGLT2i 或 GLP-1 类）的 CKM 2–4 期合并 T2D 患者，应当<strong>每 3 至 6 个月</strong>通过 HbA1c、血糖监测和/或持续葡萄糖监测评估血糖状态，未达标者增加评估频率。' },
  { cor: '2a' as const, loe: 'B-R', body: '对于开始使用肾脏保护疗法的 CKM 2–4 期伴白蛋白尿 (UACR ≥ 30 mg/g) 患者，在 <strong>3 至 6 个月后</strong>复查 UACR 是合理的，以评估残余 CKM 风险及是否需加用其他肾脏保护疗法。' },
  { cor: '2a' as const, loe: 'B-R', body: '对于开始使用作用于 RAAS 系统药物（RASi 或 MRA）的 CKM 2–4 期患者，在 <strong>2 至 4 周后</strong>估算 eGFR 并测量血钾是合理的，以评估药物方案的耐受性和安全性。' },
];

const futureRows = [
  { area: '风险预测', gap: 'PREVENT 计算器需要改进', question: '生物标志物、SDOH、亚临床 CVD 等如何进一步改进风险预测？' },
  { area: '生活方式干预', gap: '缺乏长期、多元化 CKM 人群试验', question: 'CKM 3–4 期患者中强化生活方式干预的获益和可行性如何？' },
  { area: '药物治疗', gap: '长期 GLP-1 类疗法的安全性和获益', question: '长期使用效果、心血管获益持续性、停药后果如何？' },
  { area: '多学科照护', gap: '不同人群中成本效益和实施策略', question: '哪种多学科照护模式最适合不同临床环境？' },
  { area: '卫生公平', gap: '解决健康差距的策略', question: '如何解决 SDOH、地理、经济和文化障碍？' },
  { area: '儿童青少年 CKM', gap: '纵向管理证据', question: '儿童青少年 CKM 干预对成年期的影响如何？' },
];

const futurePoints = [
  '风险预测公式的进一步精炼，纳入新兴生物标志物和影像学指标',
  'CKM 综合征进展和回归的纵向研究',
  '联合治疗策略（GLP-1 + SGLT2i + finerenone）的长期效果',
  '实施科学：如何将循证治疗有效整合到不同临床环境',
  '卫生公平：解决不同人群的 CKM 综合征负担差异',
  '教育和培训：临床医生适应 CKM 综合管理的新培训模式',
];
---

<BaseLayout title={title} description={description}>
  <PageHeader
    eyebrow="第 7–9 章 · 特殊情况与未来"
    title="特殊情况与长期监测"
    description="MASLD、阻塞性睡眠呼吸暂停、妊娠、静脉血栓栓塞——这些状况与 CKM 交织，需要特别的评估与管理策略。本章也涵盖治疗监测与未来研究方向。"
    breadcrumb="特殊情况"
  />

  {/* 导航 */}
  <section class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {navCards.map((item) => (
        <a href={item.href} class="card card-hover p-4">
          <span class="chip mb-2">{item.chip}</span>
          <p class="text-sm text-muted">{item.desc}</p>
        </a>
      ))}
    </div>
  </section>

  {/* MASLD */}
  <section id="masld" class="bg-surface/60 border-y border-line scroll-mt-20">
    <div class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="max-w-2xl mb-8">
        <p class="eyebrow mb-3">第 7.2 节</p>
        <h2 class="font-serif text-3xl font-bold text-ink mb-4">代谢功能障碍相关脂肪性肝病 (MASLD)</h2>
        <p class="text-muted leading-relaxed">MASLD 以代谢危险因素背景下的肝脏脂肪变性为特征，最近被定义用以取代"非酒精性脂肪肝 (NAFLD)"。<strong>纤维化分期最佳预测不良结局</strong>，风险评估从 FIB-4 指数开始。</p>
      </div>

      <div class="space-y-4 mb-8">
        {masldRecs.map((rec) => (
          <Recommendation cor={rec.cor} loe={rec.loe} body={rec.body} />
        ))}
      </div>

      <h3 class="font-serif text-xl font-bold text-ink mb-4">FIB-4 指数随访策略</h3>
      <div class="table-wrap"><table class="tbl">
        <thead><tr><th>年龄（岁）</th><th>FIB-4</th><th>随访</th></tr></thead>
        <tbody>
          {fib4Rows.map((row) => (
            <tr>
              <td class="num" set:html={row.age}></td>
              <td class="num" set:html={row.fib4}></td>
              <td class={row.muted ? 'text-subtle' : ''}>{row.followup}</td>
            </tr>
          ))}
        </tbody>
      </table></div>

      <div class="grid md:grid-cols-3 gap-4 mt-6">
        {masldCards.map((item) => (
          <div class="card p-5" style={`border-left:4px solid ${item.color}`}>
            <p class="font-serif text-2xl font-bold mb-1" style={`color:${item.color}`} set:html={item.title}></p>
            <p class="text-sm text-muted" set:html={item.desc}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* OSA */}
  <section id="osa" class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-14 scroll-mt-20">
    <div class="max-w-2xl mb-8">
      <p class="eyebrow mb-3">第 7.4 节</p>
      <h2 class="font-serif text-3xl font-bold text-ink mb-4">阻塞性睡眠呼吸暂停 (OSA)</h2>
      <p class="text-muted leading-relaxed">OSA 与多种 CKM 风险因素相关。CVD 和 OSA 共享许多 CKM 风险因素。预计到 2050 年美国 30–69 岁人群中 OSA 患病率显著上升至<strong>男性 55% 和女性 35%</strong>。</p>
    </div>
    <div class="space-y-4 mb-8">
      {osaRecs.map((rec) => (
        <Recommendation cor={rec.cor} loe={rec.loe} body={rec.body} />
      ))}
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      <div class="card p-5">
        <h3 class="font-serif font-bold text-ink mb-2 text-sm">筛查工具</h3>
        <p class="text-sm text-muted">STOP-BANG、Berlin questionnaire</p>
      </div>
      <div class="card p-5" style="border-left:4px solid #0f766e">
        <h3 class="font-serif font-bold text-ink mb-2 text-sm">减重获益</h3>
        <p class="text-sm text-muted">在过多体重个体中，<strong>&gt; 15% 体重减轻</strong>显著改善 OSA，AHI 评分大幅降低。</p>
      </div>
    </div>
  </section>

  {/* 妊娠 */}
  <section id="pregnancy" class="bg-surface/60 border-y border-line scroll-mt-20">
    <div class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="max-w-2xl mb-8">
        <p class="eyebrow mb-3">第 7.5 节</p>
        <h2 class="font-serif text-3xl font-bold text-ink mb-4">妊娠与 CKM 健康</h2>
        <p class="text-muted leading-relaxed">APO（不良妊娠结局，包括妊娠糖尿病、子痫前期、胎盘早剥等）与母亲后续 CVD 风险增加相关。计划妊娠前优化 CKM 风险因素对改善妊娠结局和降低长期 CVD 风险很重要。</p>
      </div>

      <h3 class="font-serif text-xl font-bold text-ink mb-4">妊娠前 CKM 管理</h3>
      <div class="space-y-4 mb-8">
        {pregnancyPreRecs.map((rec) => (
          <Recommendation cor={rec.cor} loe={rec.loe} body={rec.body} />
        ))}
      </div>

      <h3 class="font-serif text-xl font-bold text-ink mb-4 mt-10">产后 CKM 管理</h3>
      <div class="space-y-4">
        {pregnancyPostRecs.map((rec) => (
          <Recommendation cor={rec.cor} loe={rec.loe} body={rec.body} />
        ))}
      </div>
      <div class="callout callout-info mt-6 max-w-3xl">
        <p class="callout-title">关键时机</p>
        <p class="text-sm">产后随访是检测和管理新发 CKM 风险因素的<strong>关键机会</strong>。传统单次产后访视可能不足——高危女性的 CKM 风险降低咨询应在产前开始并持续到母婴产后随访完成。</p>
      </div>
    </div>
  </section>

  {/* VTE */}
  <section id="vte" class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-14 scroll-mt-20">
    <div class="max-w-2xl mb-8">
      <p class="eyebrow mb-3">第 7.3 节</p>
      <h2 class="font-serif text-3xl font-bold text-ink mb-4">静脉血栓栓塞 (VTE)</h2>
      <p class="text-muted leading-relaxed">CKM 患者 VTE 风险增加。<strong>DOAC（直接口服抗凝药）</strong>是大多数患者的首选。</p>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      {vteCards.map((item) => (
        <div class="card p-5" style={item.borderLeft ? `border-left:4px solid ${item.borderLeft}` : undefined}>
          <span
            class="chip mb-3"
            style={item.chipBg ? `background:${item.chipBg};color:${item.chipColor};border-color:${item.chipBorder}` : undefined}
          >{item.chip}</span>
          <p class="text-sm text-muted leading-relaxed" set:html={item.desc}></p>
        </div>
      ))}
    </div>
  </section>

  {/* 监测 */}
  <section id="monitoring" class="bg-surface/60 border-y border-line scroll-mt-20">
    <div class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="max-w-2xl mb-8">
        <p class="eyebrow mb-3">第 8 章 · 监测与随访</p>
        <h2 class="font-serif text-3xl font-bold text-ink mb-4">治疗开始后的监测</h2>
        <p class="text-muted leading-relaxed">CKM 药物治疗的长期获益要求患者<strong>持续耐受、依从治疗并可及药物</strong>。治疗 CKM 的药物具有可通过病史、体检和/或实验室检测确定的潜在不良反应。</p>
      </div>
      <div class="space-y-4 mb-8">
        {monitoringRecs.map((rec) => (
          <Recommendation cor={rec.cor} loe={rec.loe} body={rec.body} />
        ))}
      </div>

      <div class="grid md:grid-cols-2 gap-4">
        <div class="card p-5">
          <h3 class="font-serif font-bold text-ink mb-2 text-sm">GLP-1 类胃肠道不良反应</h3>
          <p class="text-sm text-muted">常见，应通过<strong>饮食调整、缓慢剂量滴定</strong>和必要时减量管理。</p>
        </div>
        <div class="card p-5">
          <h3 class="font-serif font-bold text-ink mb-2 text-sm">SGLT2i 监测要点</h3>
          <p class="text-sm text-muted"><strong>容量状态、肾功能、生殖器感染</strong>和罕见的 DKA 风险。</p>
        </div>
      </div>
    </div>
  </section>

  {/* 未来方向 */}
  <section id="future" class="max-w-[var(--container-content)] mx-auto px-4 sm:px-6 lg:px-8 py-16 scroll-mt-20">
    <div class="max-w-2xl mb-8">
      <p class="eyebrow mb-3">第 9 章 · 证据空白</p>
      <h2 class="font-serif text-3xl font-bold text-ink mb-4">未来研究方向</h2>
      <p class="text-muted leading-relaxed">CKM 综合征护理的多个领域存在关键证据空白，应作为未来研究重点。</p>
    </div>
    <div class="table-wrap mb-8"><table class="tbl">
      <thead><tr><th>领域</th><th>证据空白</th><th>关键研究问题</th></tr></thead>
      <tbody>
        {futureRows.map((row) => (
          <tr>
            <td><strong>{row.area}</strong></td>
            <td>{row.gap}</td>
            <td>{row.question}</td>
          </tr>
        ))}
      </tbody>
    </table></div>

    <h3 class="font-serif text-xl font-bold text-ink mb-4">未来方向要点</h3>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {futurePoints.map((point, i) => (
        <div class="card p-4 flex gap-3">
          <span class="tri-dot flex-shrink-0" style="background:#f0fdfa;color:#0f766e;border:1px solid #99f6e4;width:30px;height:30px;font-size:0.8rem">{i + 1}</span>
          <p class="text-sm text-muted">{point}</p>
        </div>
      ))}
    </div>
  </section>

  <Cta
    eyebrow="最后一步"
    title="查阅参考资源"
    description="缩略语表、术语表、关键临床试验与参考文献汇总。"
    linkHref={base + "resources/"}
    linkLabel="查看参考资源 →"
    gradient="linear-gradient(135deg,#f0fdfa,#f5f3ff)"
  />
</BaseLayout>
